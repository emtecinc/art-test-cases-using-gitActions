{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": ".",
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "tests/**/*.ts",
    "pages/**/*.ts",
    "workflows/**/*.ts",
    "data/**/*.ts",
    "global-setup.ts",
    "global-teardown.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules"]
}
